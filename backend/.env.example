# =============================================
# CREATORHUB BACKEND — ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit your real .env to git!

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/creatorhub?retryWrites=true&w=majority

# JWT Secret (generate a long random string — never reuse this)
JWT_SECRET=your_super_secret_jwt_key_change_this_to_something_long_and_random_in_production

# Frontend URL (for email links and CORS)
# Development: http://localhost:5173
# Production: https://your-vercel-app.vercel.app
CLIENT_URL=http://localhost:5173

# Email (SendGrid)
# Render blocks outbound SMTP ports, so email is sent via SendGrid's HTTPS API.
# 1. Create a free account at https://sendgrid.com
# 2. Settings → Sender Authentication → verify EMAIL_USER as a single sender
#    (or verify a whole domain) — sends are rejected from unverified senders
# 3. Settings → API Keys → create a key with "Mail Send" access
EMAIL_USER=your_verified_sender@example.com
SENDGRID_API_KEY=your_sendgrid_api_key

# Cloudinary (for image uploads)
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

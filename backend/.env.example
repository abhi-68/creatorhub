# =============================================
# CREATORHUB BACKEND — ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit your real .env to git!

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/creatorhub?retryWrites=true&w=majority

# JWT Secret (generate a long random string — never reuse this)
JWT_SECRET=your_super_secret_jwt_key_change_this_to_something_long_and_random_in_production

# Frontend URL (for email links and CORS)
# Development: http://localhost:5173
# Production: https://your-vercel-app.vercel.app
CLIENT_URL=http://localhost:5173

# Email (Mailjet)
# Render blocks outbound SMTP ports, so email is sent via Mailjet's HTTPS API.
# 1. Create a free account at https://mailjet.com (6,000 emails/month free)
# 2. Senders & Domains → Add a sender address → enter EMAIL_USER → click the
#    verification link that arrives in your inbox (no domain ownership required)
# 3. Account → API Key Management → copy API Key and Secret Key
EMAIL_USER=your_gmail@gmail.com
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key

# Cloudinary (for image uploads)
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

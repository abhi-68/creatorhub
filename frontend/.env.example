# =============================================
# CREATORHUB FRONTEND — ENVIRONMENT VARIABLES
# =============================================
# Copy to .env and fill in values

# Development: leave blank (Vite proxy handles /api → localhost:5000)
# Production: set to your Render backend URL
VITE_API_URL=

# For Socket.io in production, set to your Render backend URL
# Development: leave blank (uses current origin)
VITE_SOCKET_URL=
